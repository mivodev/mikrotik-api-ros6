{
    "name": "mivodev/mikrotik-api-ros6",
    "description": "Complete, universal PHP client for Mikrotik RouterOS v6 API (Socket Protocol Port 8728). Framework-agnostic, zero-dependency.",
    "version": "0.1.0-dev",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/mivodev/mikrotik-api-ros6",
    "support": {
        "issues": "https://github.com/mivodev/mikrotik-api-ros6/issues",
        "source": "https://github.com/mivodev/mikrotik-api-ros6"
    },
    "keywords": [
        "mikrotik",
        "routeros",
        "api",
        "ros6",
        "socket",
        "hotspot",
        "pppoe",
        "radius",
        "isp"
    ],
    "authors": [
        {
            "name": "Mivodev",
            "homepage": "https://github.com/mivodev",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "autoload": {
        "psr-4": {
            "Mivo\\MikrotikRos6\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
